# ==============================================================================
# OneGuard Configuration Template
# Copy this file to .env and fill in your credentials.
# ==============================================================================

# Network Mode: 'sandbox' (Testnet) or 'live' (Real money)
ONEGUARD_MODE=sandbox

# Exchange API Configuration
# NOTE: Disable withdrawals on these keys. Keep withdrawal permissions OFF!
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Telegram Notification Settings
# Create a bot via @BotFather to get your token, and get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Local Database Name
DATABASE_FILE=aegis_trading_bot.db

# Safety Override Switch (set to 'TRUE' to halt all new executions)
EMERGENCY_HALT=FALSE
